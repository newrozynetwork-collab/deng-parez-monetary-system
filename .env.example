# Database (leave empty for local SQLite, set for PostgreSQL on Railway)
DATABASE_URL=

# Session secret (change in production!)
SESSION_SECRET=deng-parez-secret-change-me

# Port
PORT=3000

# Google Gemini API key for the /chat assistant (free tier OK)
GEMINI_API_KEY=

# Optional: override the Gemini model. Defaults to 'gemini-2.5-flash'.
# (gemini-2.0-flash was retired by Google on 2026-06-01 — free tier quota = 0.)
# If the primary model is quota-dead/retired, the app retries once with the
# fallback below before giving up.
# GEMINI_MODEL=
# GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
