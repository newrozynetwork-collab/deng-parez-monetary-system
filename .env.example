# Database (leave empty for local SQLite, set for PostgreSQL on Railway)
DATABASE_URL=

# Session secret (change in production!)
SESSION_SECRET=deng-parez-secret-change-me

# Port
PORT=3000

# Google Gemini API key for the /chat assistant (free tier OK)
GEMINI_API_KEY=

# Optional: override the Gemini model. Defaults to 'gemini-2.0-flash'
# (free tier: 1500 requests/day). Other options:
#   gemini-2.5-flash      -- smarter but free tier is only 20 requests/day
#   gemini-2.0-flash-lite -- cheapest paid option
# GEMINI_MODEL=
